{
  "name": "modyrn",
  "version": "0.2.2",
  "private": true,
  "description": "Dashboard-first moderation for modern Discord communities.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @modyrn/database db:generate",
    "db:migrate": "pnpm --filter @modyrn/database db:migrate",
    "db:studio": "pnpm --filter @modyrn/database db:studio",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@modyrn/config": "workspace:*",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
