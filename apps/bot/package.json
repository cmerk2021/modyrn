{
  "name": "@modyrn/bot",
  "version": "0.1.3",
  "private": true,
  "description": "Modyrn bot — the discord.js gateway agent connected to the platform.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@modyrn/shared": "workspace:*",
    "discord.js": "^14.16.3",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modyrn/config": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
