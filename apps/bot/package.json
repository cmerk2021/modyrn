{
  "name": "@modyrn/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Modyrn bot — the discord.js gateway agent connected to the platform.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@modyrn/shared": "workspace:*",
    "discord.js": "^14.16.3",
    "ioredis": "^5.4.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modyrn/config": "workspace:*",
    "@types/node": "^20.16.11",
    "eslint": "^9.12.0",
    "pino-pretty": "^11.2.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
