{
  "name": "@modyrn/shared",
  "version": "0.1.3",
  "private": true,
  "description": "Shared domain types, constants and validation schemas for Modyrn.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "default": "./dist/permissions.js"
    },
    "./automod": {
      "types": "./dist/automod.d.ts",
      "default": "./dist/automod.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modyrn/config": "workspace:*",
    "eslint": "^9.12.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
