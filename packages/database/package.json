{
  "name": "@modyrn/database",
  "version": "0.1.3",
  "private": true,
  "description": "Drizzle ORM schema, migrations and typed client for Modyrn.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "tsc --project tsconfig.build.json && drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@modyrn/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@modyrn/config": "workspace:*",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
